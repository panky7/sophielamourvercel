# ============================================
# COPY THIS FILE TO .env AND FILL IN VALUES
# ============================================

# MongoDB Configuration
# Get your free MongoDB Atlas cluster at: https://www.mongodb.com/cloud/atlas
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/sophie_coaching?retryWrites=true&w=majority
DB_NAME=sophie_coaching

# JWT Secret (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Admin Credentials
ADMIN_EMAIL=admin@sophielamour.com
ADMIN_PASSWORD=YourSecureAdminPassword123!

# Frontend API URL (for local development)
REACT_APP_API_URL=http://localhost:8000
